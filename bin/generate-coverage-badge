#!/usr/bin/env php
<?php

declare(strict_types=1);

if ($argc !== 3) {
    fwrite(STDERR, "Usage: bin/generate-coverage-badge <clover.xml> <badge.svg>\n");
    exit(1);
}

[$script, $reportPath, $badgePath] = $argv;

if (! is_file($reportPath)) {
    fwrite(STDERR, "Coverage report not found: {$reportPath}\n");
    exit(1);
}

$report = simplexml_load_file($reportPath);

if (! $report instanceof SimpleXMLElement) {
    fwrite(STDERR, "Coverage report is not valid XML: {$reportPath}\n");
    exit(1);
}

$metrics = $report->xpath('//project/metrics')[0] ?? null;

if (! $metrics instanceof SimpleXMLElement) {
    fwrite(STDERR, "Coverage report does not contain project metrics: {$reportPath}\n");
    exit(1);
}

$elements = (int) $metrics['elements'];
$coveredElements = (int) $metrics['coveredelements'];

if ($elements <= 0) {
    fwrite(STDERR, "Coverage report does not contain coverable elements: {$reportPath}\n");
    exit(1);
}

$coverage = round(($coveredElements / $elements) * 100, 1);
$coverageLabel = rtrim(rtrim((string) $coverage, '0'), '.') . '%';

$color = match (true) {
    $coverage >= 90 => '#4c1',
    $coverage >= 80 => '#97ca00',
    $coverage >= 70 => '#dfb317',
    $coverage >= 60 => '#fe7d37',
    default => '#e05d44',
};

$badge = sprintf(
    <<<'SVG'
<svg xmlns="http://www.w3.org/2000/svg" width="106" height="20" role="img" aria-label="coverage: %1$s">
    <title>coverage: %1$s</title>
    <linearGradient id="s" x2="0" y2="100%%">
        <stop offset="0" stop-color="#bbb" stop-opacity=".1"/>
        <stop offset="1" stop-opacity=".1"/>
    </linearGradient>
    <clipPath id="r">
        <rect width="106" height="20" rx="3" fill="#fff"/>
    </clipPath>
    <g clip-path="url(#r)">
        <rect width="61" height="20" fill="#555"/>
        <rect x="61" width="45" height="20" fill="%2$s"/>
        <rect width="106" height="20" fill="url(#s)"/>
    </g>
    <g fill="#fff" text-anchor="middle" font-family="Verdana,Geneva,DejaVu Sans,sans-serif" text-rendering="geometricPrecision" font-size="110">
        <text aria-hidden="true" x="315" y="150" fill="#010101" fill-opacity=".3" transform="scale(.1)">coverage</text>
        <text x="315" y="140" transform="scale(.1)">coverage</text>
        <text aria-hidden="true" x="825" y="150" fill="#010101" fill-opacity=".3" transform="scale(.1)">%1$s</text>
        <text x="825" y="140" transform="scale(.1)">%1$s</text>
    </g>
</svg>
SVG,
    htmlspecialchars($coverageLabel, ENT_QUOTES | ENT_XML1),
    $color,
);

$badgeDirectory = dirname($badgePath);

if (! is_dir($badgeDirectory) && ! mkdir($badgeDirectory, 0777, true) && ! is_dir($badgeDirectory)) {
    fwrite(STDERR, "Could not create badge directory: {$badgeDirectory}\n");
    exit(1);
}

file_put_contents($badgePath, $badge . "\n");

echo "Generated {$badgePath} ({$coverageLabel})\n";
