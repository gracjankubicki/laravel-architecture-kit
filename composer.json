{
    "name": "taqie/laravel-architecture-kit",
    "description": "Opinionated Laravel architecture guidance and Boost resources for AI coding agents.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "architecture",
        "laravel",
        "guidelines",
        "boost",
        "agents",
        "ai"
    ],
    "require": {
        "php": "^8.2",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/filesystem": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "laravel/prompts": "^0.3|^1.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^11.5|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Taqie\\ArchitectureKit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Taqie\\ArchitectureKit\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test:filter": "vendor/bin/phpunit --filter"
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "Taqie\\ArchitectureKit\\ArchitectureKitServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
