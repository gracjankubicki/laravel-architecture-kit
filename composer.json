{
    "name": "gracjankubicki/laravel-architecture-kit",
    "description": "Laravel architecture guidance, application audit, and guard tooling for AI coding agents.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "architecture",
        "laravel",
        "guidelines",
        "boost",
        "agents",
        "ai"
    ],
    "require": {
        "php": "^8.3",
        "composer/semver": "^3.4",
        "illuminate/console": "^12.41.1|^13.0",
        "illuminate/filesystem": "^12.41.1|^13.0",
        "illuminate/support": "^12.41.1|^13.0",
        "laravel/mcp": "^0.8.2",
        "laravel/prompts": "^0.3|^1.0",
        "nikic/php-parser": "^5",
        "symfony/process": "^7.2|^8.0",
        "symfony/yaml": "^7.2|^8.0"
    },
    "require-dev": {
        "laravel/pint": "^1.25",
        "orchestra/testbench": "^10.0|^11.0",
        "phpunit/phpunit": "^11.5|^12.0"
    },
    "autoload": {
        "psr-4": {
            "GracjanKubicki\\ArchitectureKit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "GracjanKubicki\\ArchitectureKit\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "lint": "pint --test",
        "test": "vendor/bin/phpunit",
        "test:filter": "vendor/bin/phpunit --filter"
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "GracjanKubicki\\ArchitectureKit\\ArchitectureKitServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
